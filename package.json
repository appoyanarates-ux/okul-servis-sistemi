{
  "name": "okul-servis-tasima-sistemi",
  "private": true,
  "version": "1.3.0",
  "main": "electron.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron": "electron .",
    "electron-dev": "concurrently \"vite\" \"wait-on http://localhost:3000 && electron .\"",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@google/genai": "^1.30.0",
    "electron-updater": "^6.8.3",
    "leaflet": "1.9.4",
    "lucide-react": "0.469.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-leaflet": "4.2.1",
    "react-router-dom": "6.22.3",
    "recharts": "2.12.3",
    "xlsx": "latest"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.aypro.okulservis",
    "productName": "Okul Servis Tasima Yonetim Sistemi AyPro X",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron.js",
      "package.json",
      "updater.html"
    ],
    "win": {
      "target": "nsis"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "appoyanarates-ux",
        "repo": "okul-servis-sistemi"
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/appoyanarates-ux/okul-servis-sistemi.git"
  }
}
